# Banco de dados
DATABASE_URL="mysql://user:password@localhost:3306/seidmann_app"

# SMTP (notificações por e-mail - aulas, cobranças, confirmações de pagamento)
# Produção: Brevo (smtp-relay.brevo.com, porta 587) ou outro provedor SMTP.
# OBRIGATÓRIO EM PRODUÇÃO: SMTP_HOST, SMTP_USER, SMTP_PASS.
SMTP_HOST="mail.seidmanninstitute.com"
SMTP_PORT="587"
SMTP_USER="atendimento@seidmanninstitute.com"
SMTP_PASS="sua_senha"
# Opcional: remetente exibido (default: SMTP_USER)
# SMTP_FROM="atendimento@seidmanninstitute.com"
# Aceitar certificado autoassinado (dev ou servidor com SSL próprio). Em produção use SMTP com certificado válido.
# SMTP_INSECURE="true"

# Destinatário dos comprovantes de NF/recibo enviados pelos professores.
# Se não definido, o sistema usa financeiro@seidmanninstitute.com.
# FINANCEIRO_EMAIL="financeiro@seidmanninstitute.com"

# Cora (cobranças PIX/boleto - Integração Direta CoraPro, autenticação mTLS)
# ═══════════════════════════════════════════════════════════════════════════
# IMPORTANTE: Use credenciais de TESTE apenas em .env.local (nunca commitar).
# Em produção, configure as variáveis no painel do servidor (Vercel, etc.),
# com certificado e client-id de PRODUÇÃO — nunca suba credenciais de produção
# no repositório.
# ═══════════════════════════════════════════════════════════════════════════
#
# --- Ambiente de TESTE (stage) — use em .env.local para desenvolvimento ---
# CORA_ENVIRONMENT=stage
# CORA_CLIENT_ID=<seu client-id do ambiente de teste>
# CORA_API_URL=https://matls-clients.api.stage.cora.com.br
# CORA_AUTH_URL=https://matls-clients.api.stage.cora.com.br/token
# CORA_CERT_PATH=./certs-stage/certificate.pem
# CORA_KEY_PATH=./certs-stage/private-key.key
#
# --- Produção (só no servidor, não commitar) ---
CORA_CLIENT_ID=
CORA_API_URL=https://matls-clients.api.cora.com.br
CORA_AUTH_URL=https://matls-clients.api.cora.com.br/token
CORA_CERT_PATH=./certs/certificate.pem
CORA_KEY_PATH=./certs/private-key.pem
CORA_ENVIRONMENT=production
CORA_WEBHOOK_SECRET=
# Opcional: valor fixo mensal estimado de gastos Cora (ex: 150.50).
# CORA_ESTIMATED_MONTHLY=150.50

# Cron: jobs rodam via node-cron no próprio servidor (instrumentation.ts).
# Endpoints /api/cron/* protegidos por autenticação admin para disparo manual.

# Focus NFe - NFSe
# Token fornecido no painel da Focus NFe (diferente do token da Cora)
FOCUS_NFE_TOKEN=
FOCUS_NFE_ENVIRONMENT=sandbox
NFSE_ENABLED=false
# Opcional: para checagem client-side (a página de NFSe usa a resposta da API GET /api/admin/nfse)
# NEXT_PUBLIC_NFSE_ENABLED=true

# Notificações de pagamento (cron payment-notifications)
# Nº de dias de atraso após os quais a matrícula é suspensa automaticamente (default: 8)
# PAYMENT_OVERDUE_DAYS_LIMIT=8

# Google Drive – upload de NF/recibo (Financeiro – Administração)
# Pasta: https://drive.google.com/drive/folders/1-yzM-Hf1DZ36-KZizqilRGUZE5hNvqJV
# Compartilhe a pasta com o e-mail da Service Account (Editor).
# GOOGLE_DRIVE_FOLDER_ID=1-yzM-Hf1DZ36-KZizqilRGUZE5hNvqJV
# GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
